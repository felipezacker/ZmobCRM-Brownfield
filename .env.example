# ============================================
# ZmobCRM — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local with real credentials
# ============================================

# --------------------------------------------
# Supabase (required)
# --------------------------------------------
# Get from: Supabase Dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# New key format (Nov 2025): sb_publishable_...
# Fallback: NEXT_PUBLIC_SUPABASE_ANON_KEY (legacy anon key format)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only: sb_secret_... (NEVER expose to client)
# Fallback: SUPABASE_SERVICE_ROLE_KEY (legacy format)
SUPABASE_SECRET_KEY=

# --------------------------------------------
# Sentry (optional — error tracking)
# --------------------------------------------

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# --------------------------------------------
# Installer (optional — first-time setup wizard)
# --------------------------------------------

# INSTALLER_ENABLED=true
# INSTALLER_TOKEN=

# --------------------------------------------
# Vercel (auto-injected in Vercel deployments)
# --------------------------------------------

# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# --------------------------------------------
# Development-only flags
# --------------------------------------------

# ALLOW_AI_TEST_ROUTE=true          # Enable /api/ai/test and /ai-test page
# ALLOW_UI_MOCKS_ROUTE=true         # Enable /labs/* mock pages
# AI_TOOL_APPROVAL_BYPASS=true      # Skip AI tool approval prompts
# AI_TOOL_CALLS_DEBUG=true          # Log AI tool calls to console
# NEXT_PUBLIC_DEBUG_REALTIME=true   # Log realtime events to console

# --------------------------------------------
# Resend (optional — email transacional)
# --------------------------------------------
# Get from: resend.com > API Keys
RESEND_API_KEY=
